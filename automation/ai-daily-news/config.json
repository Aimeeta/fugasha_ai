    { "name": "Hugging Face Blog", "url": "https://huggingface.co/blog/feed.xml", "sourceType": "official", "sourceName": "Hugging Face" }
  ],
  "feedsDisabled": [
    { "name": "Google DeepMind Blog", "url": "https://deepmind.google/blog/rss.xml", "sourceType": "official", "sourceName": "Google DeepMind" },
    { "name": "NVIDIA Blog", "url": "https://blogs.nvidia.com/feed/", "sourceType": "official", "sourceName": "NVIDIA" },
    { "name": "GitHub Blog (AI)", "url": "https://github.blog/ai-and-ml/feed/", "sourceType": "official", "sourceName": "GitHub" },
    { "name": "MIT Technology Review (AI)", "url": "https://www.technologyreview.com/topic/artificial-intelligence/feed", "sourceType": "media", "sourceName": "MIT Technology Review" },
    { "name": "The Verge (AI)", "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml", "sourceType": "media", "sourceName": "The Verge" }
  ],
  "allowedLinkDomains": ["openai.com", "huggingface.co"],
  "_faviconComment": "出典リストのfavicon。既存記事と同じ自己ホスト方式（assets/favicons/）。ドメイン追加時はPNGを置いてここに追記。無いドメインは頭文字表示にフォールバック",
