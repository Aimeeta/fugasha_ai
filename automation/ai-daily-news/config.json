{
  "_comment": "AI Daily News の設定。feeds は最小構成（公式RSS 2本）から始める。追加候補は feedsDisabled を feeds へ移し、allowedLinkDomains にドメインを足すこと。",
  "feeds": [
    { "name": "OpenAI News", "url": "https://openai.com/news/rss.xml", "sourceType": "official", "sourceName": "OpenAI" },
    { "name": "Hugging Face Blog", "url": "https://huggingface.co/blog/feed.xml", "sourceType": "official", "sourceName": "Hugging Face" },
    { "name": "GitHub Blog (AI)", "url": "https://github.blog/ai-and-ml/feed/", "sourceType": "official", "sourceName": "GitHub" },
    { "name": "The Verge (AI)", "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml", "sourceType": "media", "sourceName": "The Verge" },
    { "name": "MIT Technology Review (AI)", "url": "https://www.technologyreview.com/topic/artificial-intelligence/feed", "sourceType": "media", "sourceName": "MIT Technology Review" }
  ],
  "feedsDisabled": [
    { "name": "Google DeepMind Blog", "url": "https://deepmind.google/blog/rss.xml", "sourceType": "official", "sourceName": "Google DeepMind" },
    { "name": "NVIDIA Blog", "url": "https://blogs.nvidia.com/feed/", "sourceType": "official", "sourceName": "NVIDIA", "_note": "一般ブログでゲーム等の非AI記事が多い。有効化する場合はLLM選定の負荷に注意" }
  ],
  "allowedLinkDomains": ["openai.com", "huggingface.co", "github.blog", "theverge.com", "technologyreview.com"],
  "_faviconComment": "出典リストのfavicon。既存記事と同じ自己ホスト方式（assets/favicons/）。ドメイン追加時はPNGを置いてここに追記。無いドメインは頭文字表示にフォールバック",
  "faviconFiles": { "openai.com": "openai.png", "huggingface.co": "huggingface.png", "github.blog": "github.png", "theverge.com": "theverge.png", "technologyreview.com": "mittr.png" },
  "windowHours": 48,
  "extendedWindowHours": 72,
  "minItems": 3,
  "maxItems": 5,
  "maxCandidates": 20,
  "_deepDiveComment": "サマリーとは別に、実在ソースに紐づく深掘り解説記事を毎日最大 max 本自動生成する。出典ありき（groundIdは必ず候補内の実在id）で、捏造防止の保証はサマリーと同じ。minBodyChars 未満の薄い記事は投稿しない。",
  "deepDive": {
    "max": 2,
    "maxTokens": 6000,
    "minBodyChars": 500
  },
  "usedUrlRetentionDays": 7,
  "categories": ["AI Models", "AI Agents", "Creative AI", "Business", "Research", "Robotics", "Policy", "Society", "Open Source", "Tools"],
  "site": {
    "baseUrl": "https://aimeeta.github.io/fugasha_ai",
    "articleDirPrefix": "ai-daily"
  },
  "llm": {
    "_comment": "temperature は Sonnet 5 以降で廃止されたため設定しない。古いモデルを使う場合のみ temperature を数値で足すと送信される",
    "model": "claude-sonnet-5",
    "maxTokens": 3500
  }
}
